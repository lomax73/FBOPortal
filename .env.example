# Copiare in .env e valorizzare. Non committare mai .env.

DJANGO_SECRET_KEY=
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# In produzione (vedi deploy/README.md): nessun dominio configurato sul VPS,
# quindi DJANGO_ALLOWED_HOSTS=94.177.161.127 (IP nudo, provvisorio finché
# non esiste un dominio reale — allora si passa a un sottodominio dedicato,
# vedi deploy/nginx-portal.conf).
#
# Se il Portale gira dietro Nginx su una porta non standard (es. 8443,
# come in produzione oggi perché la 443 è già usata da MKRemote), Nginx
# deve inoltrare `proxy_set_header Host $http_host;` (non $host, che
# perde la porta) — altrimenti il controllo CSRF di Django fallisce in
# login con 403 (Referer del browser include la porta, Host ricevuto da
# Django no). Non serve nessuna DJANGO_CSRF_TRUSTED_ORIGINS extra: basta
# questo fix lato Nginx.
